+package com.ragnar.primordialauthority.zone;
+
+// Rename this file to ZoneType.java when you are ready.
+public enum ZoneType {
+    ANTI_SKILL("anti_skill"),
+    EP_BONUS("ep_bonus"),
+    CORRUPTED("corrupted"),
+    PURIFICATION("purification");
+
+    private final String id;
+
+    ZoneType(String id) {
+        this.id = id;
+    }
+
+    public String id() {
+        return id;
+    }
+
+    public static ZoneType byId(String id) {
+        for (ZoneType type : values()) {
+            if (type.id.equals(id)) {
+                return type;
+            }
+        }
+
+        return CORRUPTED;
+    }
+}
