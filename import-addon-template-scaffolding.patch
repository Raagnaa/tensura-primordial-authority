+package com.ragnar.primordialauthority.zone;
+
+import net.minecraft.core.BlockPos;
+import net.minecraft.nbt.CompoundTag;
+import net.minecraft.resources.ResourceKey;
+import net.minecraft.resources.ResourceLocation;
+import net.minecraft.world.level.Level;
+
+// Rename this file to SpecialZone.java when you are ready.
+public class SpecialZone {
+    private final ZoneType type;
+    private final ResourceKey<Level> dimension;
+    private final BlockPos center;
+    private final int radius;
+
+    public SpecialZone(ZoneType type, ResourceKey<Level> dimension, BlockPos center, int radius) {
+        this.type = type;
+        this.dimension = dimension;
+        this.center = center;
+        this.radius = radius;
+    }
+
+    public boolean contains(Level level, BlockPos pos) {
+        return level.dimension().equals(dimension) && center.distSqr(pos) <= radius * radius;
+    }
+
+    public ZoneType type() {
+        return type;
+    }
+
+    public CompoundTag save() {
+        CompoundTag tag = new CompoundTag();
+        tag.putString("type", type.id());
+        tag.putString("dimension", dimension.location().toString());
+        tag.putInt("x", center.getX());
+        tag.putInt("y", center.getY());
+        tag.putInt("z", center.getZ());
+        tag.putInt("radius", radius);
+        return tag;
+    }
+
+    public static SpecialZone load(CompoundTag tag) {
+        ResourceKey<Level> dimension = ResourceKey.create(
+                net.minecraft.core.registries.Registries.DIMENSION,
+                ResourceLocation.parse(tag.getString("dimension"))
+        );
+        return new SpecialZone(
+                ZoneType.byId(tag.getString("type")),
+                dimension,
+                new BlockPos(tag.getInt("x"), tag.getInt("y"), tag.getInt("z")),
+                tag.getInt("radius")
+        );
+    }
+}
