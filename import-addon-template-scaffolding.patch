+package com.ragnar.primordialauthority.zone;
+
+import io.github.manasmods.manascore.storage.api.Storage;
+import io.github.manasmods.manascore.storage.api.StorageHolder;
+import io.github.manasmods.manascore.storage.api.StorageKey;
+import net.minecraft.nbt.CompoundTag;
+import net.minecraft.nbt.ListTag;
+import net.minecraft.nbt.Tag;
+
+import java.util.ArrayList;
+import java.util.List;
+
+// Rename this file to ZoneStorage.java when you are ready.
+// Store zones in world storage because zones belong to the level, not to one player.
+public class ZoneStorage extends Storage {
+    public static StorageKey<ZoneStorage> KEY;
+
+    private final List<SpecialZone> zones = new ArrayList<>();
+
+    public ZoneStorage(StorageHolder holder) {
+        super(holder);
+    }
+
+    public List<SpecialZone> zones() {
+        return zones;
+    }
+
+    public boolean isInZone(net.minecraft.world.entity.LivingEntity entity, ZoneType type) {
+        return zones.stream().anyMatch(zone -> zone.type() == type && zone.contains(entity.level(), entity.blockPosition()));
+    }
+
+    public void addZone(SpecialZone zone) {
+        zones.add(zone);
+        markDirty();
+    }
+
+    @Override
+    public void save(CompoundTag data) {
+        ListTag list = new ListTag();
+
+        for (SpecialZone zone : zones) {
+            list.add(zone.save());
+        }
+
+        data.put("zones", list);
+    }
+
+    @Override
+    public void load(CompoundTag data) {
+        zones.clear();
+        ListTag list = data.getList("zones", Tag.TAG_COMPOUND);
+
+        for (int i = 0; i < list.size(); i++) {
+            zones.add(SpecialZone.load(list.getCompound(i)));
+        }
+    }
+}
