+package com.ragnar.primordialauthority.zone;
+
+import io.github.manasmods.manascore.storage.api.StorageHolder;
+import net.minecraft.world.entity.LivingEntity;
+
+// Rename this file to ZoneHelper.java after ZoneStorage.java is active.
+// Keep lookup logic here so events and skills stay small.
+public final class ZoneHelper {
+    private ZoneHelper() {
+    }
+
+    public static boolean isInZone(LivingEntity entity, ZoneType type) {
+        if (entity.level().isClientSide()) {
+            return false;
+        }
+
+        StorageHolder holder = (StorageHolder) entity.level();
+        ZoneStorage storage = holder.manasCore$getStorage(ZoneStorage.KEY);
+        return storage != null && storage.isInZone(entity, type);
+    }
+}
