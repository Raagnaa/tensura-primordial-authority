+package com.ragnar.primordialauthority.zone;
+
+import dev.architectury.event.EventResult;
+import io.github.manasmods.manascore.skill.api.SkillEvents;
+import net.minecraft.network.chat.Component;
+import net.minecraft.world.entity.LivingEntity;
+
+// Rename this file to ZoneEvents.java after ZoneStorage and ZoneHelper are active.
+// This shows how a zone can affect skills. Add EP multipliers later after reviewing Tensura's EP API.
+public final class ZoneEvents {
+    private ZoneEvents() {
+    }
+
+    public static void init() {
+        SkillEvents.ACTIVATE_SKILL.register((skillInstance, owner, keyNumber, mode) -> {
+            if (isInAntiSkillZone(owner)) {
+                owner.sendSystemMessage(Component.literal("Skills are sealed in this area."));
+                return EventResult.interruptFalse();
+            }
+
+            return EventResult.pass();
+        });
+    }
+
+    private static boolean isInAntiSkillZone(LivingEntity entity) {
+        return ZoneHelper.isInZone(entity, ZoneType.ANTI_SKILL);
+    }
+}
